@page "/traces"
@model TracesModel

<section>
    <h2>Traces</h2>
    <div class="table-scroll">
        <table>
            <thead>
                <tr>
                    <th aria-label="Expand"></th>
                    <th>TraceId</th>
                    <th>ClientKind</th>
                    <th>TotalTokens</th>
                    <th>ToolCallCount</th>
                    <th>ErrorCount</th>
                    <th>TurnCount</th>
                    <th>PrimaryModel</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.Result.Items)
                {
                    <tr>
                        <td>
                            <button class="row-toggle" type="button" aria-expanded="false" aria-controls="trace-extra-@row.Id" aria-label="Toggle trace details">+</button>
                        </td>
                        <td><a href="/traces/@row.TraceId">@row.TraceId</a></td>
                        <td>@row.ClientKind</td>
                        <td>@row.TotalTokens</td>
                        <td>@row.ToolCallCount</td>
                        <td class="@(row.ErrorCount > 0 ? "status-error" : null)">@row.ErrorCount</td>
                        <td>@row.TurnCount</td>
                        <td>@row.PrimaryModel</td>
                    </tr>
                    <tr class="trace-extra" id="trace-extra-@row.Id" hidden>
                        <td colspan="8">
                            <dl>
                                <dt>Id</dt><dd>@row.Id</dd>
                                <dt>ExperimentId</dt><dd>@row.ExperimentId</dd>
                                <dt>TaskId</dt><dd>@row.TaskId</dd>
                                <dt>TaskCategory</dt><dd>@row.TaskCategory</dd>
                                <dt>AgentVariant</dt><dd>@row.AgentVariant</dd>
                                <dt>PromptVersion</dt><dd>@row.PromptVersion</dd>
                                <dt>SpanCount</dt><dd>@row.SpanCount</dd>
                                <dt>InputTokens</dt><dd>@row.InputTokens</dd>
                                <dt>OutputTokens</dt><dd>@row.OutputTokens</dd>
                                <dt>AgentInvocationCount</dt><dd>@row.AgentInvocationCount</dd>
                                <dt>DurationMs</dt><dd>@row.DurationMs</dd>
                                <dt>FirstSeenAt</dt><dd>@row.FirstSeenAt</dd>
                                <dt>LastSeenAt</dt><dd>@row.LastSeenAt</dd>
                                <dt>ProjectedAt</dt><dd>@row.ProjectedAt</dd>
                            </dl>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Result.HasMore && Model.Result.Items.Count > 0)
    {
        <p><a href="/traces?after=@Model.Result.Items[^1].Id">next</a></p>
    }
</section>
